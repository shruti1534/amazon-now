# ── NVIDIA AI Endpoints ────────────────────────────────────────────────────
NVIDIA_API_KEY=nvapi-xxxx-your-key-here
NVIDIA_MODEL_ID=z-ai/glm-5.1
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=1
NVIDIA_MAX_TOKENS=16384

# ── AWS (DynamoDB only) ────────────────────────────────────────────────────
AWS_REGION=us-east-1
DYNAMODB_PRODUCTS_TABLE=amazon-now-products
DYNAMODB_ORDERS_TABLE=amazon-now-orders

# ── App ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000"]
